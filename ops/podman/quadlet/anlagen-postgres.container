[Unit]
Description=Anlagen PostgreSQL
After=network-online.target

[Container]
Image=docker.io/library/postgres:16-alpine
ContainerName=anlagen-postgres
EnvironmentFile=/srv/anlagenserver/config/postgres.env
Volume=/srv/anlagenserver/pgdata:/var/lib/postgresql/data:Z
Network=anlagen-net

[Service]
Restart=always

[Install]
WantedBy=multi-user.target
